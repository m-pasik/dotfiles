xrandr --output DVI-D-0 --off --output DP-1 --mode 1920x1080 --rate 144 --pos 0x506 --rotate normal --output DP-4 --rotate left --off --output DP-1 --off --output DP-4 --mode 1680x1050 --rate 60 --pos 1920x0 --rotate left --output DP-3 --off --output DP-4 --off --output DP-5 --off
export TERMINAL=/usr/bin/alacritty
setxkbmap pl
setxkbmap -option "compose:rctrl"
picom --xrender-sync-fence &
dunst &
lxpolkit &
flameshot &
copyq &
ibus-daemon -drxR
lxsession-xdg-autostart &
nm-applet &
xwallpaper --zoom '/usr/share/backgrounds/archlinux/split.png' &
[[ -f ~/.Xresources ]] && xrdb -merge -I$HOME ~/.Xresources &
$HOME/tablet.sh &
#setsid conky -d &
